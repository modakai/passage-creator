# 后端服务的完整根地址（必须以 http/https 开头，结尾不要加 /）
VITE_SERVER_API_URL=https://example.com
# 后端接口的统一前缀（比如所有接口都以 /api 开头，结尾不要加 /）
VITE_SERVER_API_PREFIX=/api
# 后端接口请求的超时时间，单位毫秒
VITE_SERVER_API_TIMEOUT=8000
# Token 主请求头名称
VITE_AUTH_TOKEN_HEADER_NAME=Authorization
# Token 主请求头前缀
VITE_AUTH_TOKEN_HEADER_PREFIX="Bearer "
# 是否兼容旧 token 请求头
VITE_AUTH_COMPATIBILITY_TOKEN_HEADER_ENABLED=true
# 兼容旧 token 请求头名称
VITE_AUTH_COMPATIBILITY_TOKEN_HEADER_NAME=token
VITE_APP_TITLE=Sakura Admin